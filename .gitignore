# ============================================================
#  DEFAULT .gitignore
# ============================================================

# ── OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors & IDEs ──────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
.env
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
dist/
build/
*.egg-info/
*.egg
MANIFEST
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Node.js ─────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.pnp.*
.next/
.nuxt/
dist/
.cache/
.parcel-cache/
.turbo/
out/

# ── Rust ────────────────────────────────────────────────────
target/
Cargo.lock          # remove this line for binaries (keep for libs)
**/*.rs.bk

# ── Go ──────────────────────────────────────────────────────
*.exe
*.exe~
*.test
*.out
vendor/

# ── Java / Kotlin ───────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*

# ── Docker ──────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ── Terraform ───────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
crash.log
override.tf
override.tf.json

# ── ML / Data Science ───────────────────────────────────────
*.h5
*.hdf5
*.pkl
*.pickle
*.pt
*.pth
*.onnx
*.bin
data/raw/
data/processed/
models/
checkpoints/
wandb/
mlruns/
*.csv          # remove if you want to track data
*.parquet

# ── Secrets & Credentials ───────────────────────────────────
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
config/local.*

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Compiled / Binary ───────────────────────────────────────
*.o
*.a
*.so
*.dylib
*.dll

# ── Misc ────────────────────────────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.bak
*.orig
*.rej
.env
